PORT=3000
NODE_ENV=development

# JWT
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_RS256_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# Downstream Services
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
VIDEO_SERVICE_URL=http://localhost:3003

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Jaeger
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Rate Limiting
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT_UNAUTHENTICATED=10
THROTTLE_LIMIT_AUTHENTICATED=60
THROTTLE_LIMIT_ADMIN=200

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=5000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Request Timeout (ms)
REQUEST_TIMEOUT=10000

# Cache TTL (seconds)
CACHE_TTL_SECONDS=300
